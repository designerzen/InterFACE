block scripts
	script(type="module").
		import Reveal from 'reveal.js'
		import RevealNotes from 'reveal.js/dist/plugin/notes.js'
		import {default as QRCodeSVG} from 'qrcode-svg'

		let deck = new Reveal({
			// Display presentation control arrows
			// - true:      Show controls
			// - false:     Hide controls
			// - 'speaker': Show controls only in the speaker view
			controls:"speaker",
			totalTime: 45 * 60,
			plugins: [RevealNotes],
			disableLayout: true,
			// allow reload to point
			hash: true,
			// Transition style
			transition: 'fade', // none/fade/slide/convex/concave/zoom

			// Transition speed
			transitionSpeed: 'default', // default/fast/slow

			// Transition style for full page slide backgrounds
			backgroundTransition: 'fade', // none/fade/slide/convex/concave/zoom

			display:"flex",
			// Activate the scroll view
			//- view: 'scroll',
			// Force the scrollbar to remain visible
			//- scrollProgress: true,
			
			// Hide cursor if inactive
			hideInactiveCursor: true
		})
		
		const anchors = document.querySelectorAll("a[href]")
		const qrcodes = []
		// add QR codes to URLs...
		anchors.forEach( anchor => {
			const qrcode = new QRCodeSVG(anchor.href)
			const qrElement = document.createElement("div")
			qrElement.innerHTML = qrcode.svg()
			anchor.appendChild(qrElement)
			qrcodes.push(qrcode)
			console.log("Initialising QR Codes", qrcodes, anchors )
		})

		deck.initialize()
		
		console.log("Initialising Presentation", {deck, RevealNotes})
		
