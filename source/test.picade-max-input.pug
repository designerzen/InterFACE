block scripts
	script(type="module").
		import {
			PlasmaButtons, LedMatrix, RGBl,
			DISPLAY_GALACTIC_UNICORN, DISPLAY_INTERSTATE75_128x32,
			COLOR_ORDER_RGB, COLOR_ORDER_RBG, COLOR_ORDER_GBR,
			COLOR_ORDER_GRB, COLOR_ORDER_BGR, COLOR_ORDER_BRG
		} from './hardware/gamepad/picade-max-input.js'
		import {
			PICADE_MAX_BUTTON_MAP,
			PICADE_MAX_COORD_MAP,
			PICADE_6_BUTTON_LABELS,
			BUTTON_PATTERN_NAMES,
			PICADE_MAX_NUM_LEDS,
			PICADE_MAX_PACKET_LED_COUNT,
			PICADE_MAX_REFRESH_RATE,
			runExamples3,
			runExamplesButtonDemo,
			runButtonPattern,
			runExamplesMatrixDemo,
		} from './hardware/gamepad/picade-max-examples.js'

		const hasSerial = 'serial' in navigator
		if (!hasSerial) document.getElementById('serialWarning').style.display = 'block'

		function hexToRGBl(hex, brightness) {
			const n = parseInt(hex.slice(1), 16)
			return RGBl((n >> 16) & 0xff, (n >> 8) & 0xff, n & 0xff, brightness)
		}

		function rgblToHex(c) {
			return '#' + [c.red, c.green, c.blue].map(v => v.toString(16).padStart(2, '0')).join('')
		}

		const $ = id => document.getElementById(id)

		const COLOR_ORDERS = { RGB: COLOR_ORDER_RGB, RBG: COLOR_ORDER_RBG, GBR: COLOR_ORDER_GBR, GRB: COLOR_ORDER_GRB, BGR: COLOR_ORDER_BGR, BRG: COLOR_ORDER_BRG }
		const DISPLAY_MAP = { 0: DISPLAY_GALACTIC_UNICORN, 1: DISPLAY_INTERSTATE75_128x32 }
		const LED_SLOT_NAMES = ['Top left', 'Top right', 'Bottom left', 'Bottom right']

		let buttons = null
		let matrix = null
		let activeTab = 'buttons'
		let selectedLed = 0
		let previewColors = []
		let previewRaf = null
		let buttonExampleAbort = null
		let matrixExampleAbort = null

		// tabs
		document.querySelectorAll('.tab').forEach(tab => {
			tab.addEventListener('click', () => {
				document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'))
				document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'))
				tab.classList.add('active')
				document.querySelector(`.panel[data-tab="${tab.dataset.tab}"]`).classList.add('active')
				activeTab = tab.dataset.tab
			})
		})

		// serial log
		const logEl = $('serialLog')
		function logEntry(cls, msg) {
			const time = new Date().toLocaleTimeString('en-GB', { hour12: false, fractionalSecondDigits: 1 })
			const line = document.createElement('div')
			line.innerHTML = `<span class="log-time">${time}</span><span class="${cls}">${msg}</span>`
			logEl.appendChild(line)
			logEl.scrollTop = logEl.scrollHeight
		}
		$('btnClearLog').addEventListener('click', () => logEl.innerHTML = '')

		function updateStats() {
			const device = buttons || matrix
			if (!device) { $('statsLabel').textContent = ''; return }
			const s = device.stats
			$('statsLabel').textContent = `TX: ${s.bytesWritten} B  RX: ${s.bytesRead} B`
		}
		setInterval(updateStats, 500)

		function hexDump(arr, max = 64) {
			const bytes = Array.from(arr.slice(0, max))
			const hex = bytes.map(b => b.toString(16).padStart(2, '0')).join(' ')
			return hex + (arr.length > max ? ` … (${arr.length}B total)` : '')
		}

		function updatePortInfo(device) {
			const info = device.portInfo
			if (!info) { $('portInfo').textContent = ''; return }
			$('portInfo').textContent = `USB vendor: 0x${(info.vendorId||0).toString(16).padStart(4,'0')}  product: 0x${(info.productId||0).toString(16).padStart(4,'0')}`
		}

		let txThrottle = 0
		function attachDeviceListeners(device) {
			device.on('connect', info => {
				logEntry('log-info', `✓ Connected  vendor:0x${(info.vendorId||0).toString(16).padStart(4,'0')}  product:0x${(info.productId||0).toString(16).padStart(4,'0')}`)
				updatePortInfo(device)
			})
			device.on('data', ({ raw, text, length }) => {
				const clean = text.replace(/[^\x20-\x7E\n\r]/g, '·')
				logEntry('log-in', `← ${length}B: ${clean}`)
				if ($('chkHexDump').checked) {
					logEntry('log-hex', `   ${hexDump(raw)}`)
				}
			})
			device.on('tx', ({ raw, length }) => {
				if (!$('chkHexDump').checked) return
				const now = Date.now()
				if (now - txThrottle < 500) return
				txThrottle = now
				const prefix = Array.from(raw.slice(0, 15)).map(b => String.fromCharCode(b)).join('')
				logEntry('log-out', `→ ${length}B  prefix: "${prefix}"`)
				logEntry('log-hex', `   ${hexDump(raw)}`)
			})
			device.on('error', ({ message }) => {
				logEntry('log-err', `✗ ${message}`)
			})
			device.on('disconnect', () => {
				stopButtonExample()
				stopMatrixExample()
				logEntry('log-info', '○ Disconnected')
				$('portInfo').textContent = ''
			})
		}

		// diagnostics buttons
		$('btnTestPattern').addEventListener('click', async () => {
			const device = activeTab === 'buttons' ? buttons : matrix
			if (!device?.connected) { logEntry('log-err', 'Not connected'); return }
			const prefix = new TextEncoder().encode('multiverse:data')
			let test
			if (activeTab === 'buttons') {
				const payload = new Uint8Array(buttons.packetByteLength)
				payload.set([
					0x00, 0x00, 0xFF, 0x1F,
					0x00, 0xFF, 0x00, 0x1F,
					0xFF, 0x00, 0x00, 0x1F,
					0xFF, 0xFF, 0xFF, 0x1F,
				], 0)
				test = new Uint8Array(prefix.length + payload.length)
				test.set(prefix, 0)
				test.set(payload, prefix.length)
				logEntry('log-out', `→ Test pattern: full ${buttons.packetByteLength / 4} LED transport frame with first 4 logical LEDs set`)
			} else {
				test = new Uint8Array([
					...prefix,
					0x00, 0x00, 0xFF, 0x1F,
					0x00, 0xFF, 0x00, 0x1F,
					0xFF, 0x00, 0x00, 0x1F,
					0xFF, 0xFF, 0xFF, 0x1F,
				])
				logEntry('log-out', '→ Matrix test pattern: first 4 pixels set')
			}
			logEntry('log-hex', `   ${hexDump(test, 128)}`)
			await device.sendRaw(test)
		})

		$('btnSendRaw').addEventListener('click', async () => {
			const device = activeTab === 'buttons' ? buttons : matrix
			if (!device?.connected) { logEntry('log-err', 'Not connected'); return }
			const text = prompt('Enter raw text to send (will be UTF-8 encoded):')
			if (!text) return
			logEntry('log-out', `→ Raw: "${text}"`)
			await device.sendRaw(text)
		})

		// connection
		let connectedMode = null

		function stopButtonExample() {
			if (buttonExampleAbort) {
				buttonExampleAbort.abort()
				buttonExampleAbort = null
			}
		}

		function stopMatrixExample() {
			if (matrixExampleAbort) {
				matrixExampleAbort.abort()
				matrixExampleAbort = null
			}
		}

		function updateConnectionUI(connected) {
			$('statusDot').classList.toggle('ok', connected)
			$('statusLabel').textContent = connected ? `Connected (${connectedMode})` : 'Disconnected'
			$('btnConnect').textContent = connected ? 'Disconnect' : 'Connect'
		}

		$('btnConnect').addEventListener('click', async () => {
			try {
				if (activeTab === 'buttons' && buttons?.connected) {
					stopButtonExample()
					await buttons.disconnect(); connectedMode = null; updateConnectionUI(false); return
				}
				if (activeTab === 'matrix' && matrix?.connected) {
					stopMatrixExample()
					await matrix.disconnect(); connectedMode = null; updateConnectionUI(false); return
				}
				if (!hasSerial) { alert('WebSerial not available'); return }
				if (activeTab === 'buttons') {
					if (!buttons) ensureButtons()
					attachDeviceListeners(buttons)
					logEntry('log-info', '… Requesting serial port…')
					await buttons.connect()
					connectedMode = 'buttons'
				} else {
					if (!matrix) ensureMatrix()
					attachDeviceListeners(matrix)
					logEntry('log-info', '… Requesting serial port…')
					await matrix.connect()
					connectedMode = 'matrix'
				}
				updateConnectionUI(true)
			} catch (e) {
				if (e.name === 'NotFoundError') {
					logEntry('log-err', 'No port selected')
				} else {
					logEntry('log-err', `Connection failed: ${e.message}`)
					console.error(e)
				}
			}
		})

		// range value displays
		function bindRange(sliderId, valId) {
			const s = $(sliderId), v = $(valId)
			s.addEventListener('input', () => v.textContent = s.value)
		}
		bindRange('ledBrightness', 'ledBrightnessVal')
		bindRange('ledTransition', 'ledTransitionVal')
		bindRange('attractDelay', 'attractDelayVal')
		bindRange('matrixBrightness', 'matrixBrightnessVal')

		// ═══════════════ BUTTONS ═══════════════

		function buildFallbackCoordMap(n) {
			const coordMap = {}
			const cols = Math.ceil(Math.sqrt(n))
			for (let i = 0; i < n; i++) {
				coordMap[`${i % cols},${Math.floor(i / cols)}`] = i
			}
			return coordMap
		}

		function syncPicadeMaxInputs() {
			$('numLeds').value = String(PICADE_MAX_NUM_LEDS)
			$('refreshRate').value = String(PICADE_MAX_REFRESH_RATE)
		}

		function getButtonLabelByNumber(buttonNumber) {
			for (const [label, value] of Object.entries(buttons?.buttonMap || {})) {
				if (value === buttonNumber) return label
			}
			return null
		}

		function formatButtonLabel(label) {
			return label ? label.replace('P1:', '') : 'Unknown'
		}

		function getSelectedButtonNumber() {
			return Math.floor(selectedLed / 4)
		}

		function updateLayoutSummary() {
			if (!buttons) return
			$('layoutSummary').textContent = buttons.numLeds === PICADE_MAX_NUM_LEDS ? 'Original 6-button Picade' : 'Custom test layout'
			$('logicalLedSummary').textContent = String(buttons.numLeds)
			$('transportLedSummary').textContent = `${buttons.packetLedCount} LEDs`
			$('refreshSummary').textContent = `~${buttons.maxFrameRate} fps max`
		}

		function updateSelectionSummary() {
			const buttonNumber = getSelectedButtonNumber()
			const label = getButtonLabelByNumber(buttonNumber)
			$('selectedIdx').textContent = String(selectedLed)
			$('selectedButtonLabel').textContent = formatButtonLabel(label || `P1:${buttonNumber + 1}`)
			$('selectedLightLabel').textContent = LED_SLOT_NAMES[selectedLed % 4] || 'Unknown'
		}

		function applyToButton(buttonNumber, settings) {
			const start = buttonNumber * 4
			for (let i = start; i < start + 4 && i < buttons.numLeds; i++) {
				applyToLed(i, settings)
			}
		}

		function ensureButtons() {
			const n = parseInt($('numLeds').value) || 16
			const r = parseInt($('refreshRate').value) || 20
			const usePicadeMaxMaps = n === PICADE_MAX_NUM_LEDS
			const coordMap = usePicadeMaxMaps ? { ...PICADE_MAX_COORD_MAP } : buildFallbackCoordMap(n)
			const buttonMap = usePicadeMaxMaps ? { ...PICADE_MAX_BUTTON_MAP } : {}
			buttons = new PlasmaButtons(n, {
				refreshRate: r,
				packetLedCount: usePicadeMaxMaps ? PICADE_MAX_PACKET_LED_COUNT : n,
				coordMap,
				buttonMap
			})
			previewColors = Array.from({ length: n }, () => ({ colorTo: RGBl(0,0,0,0), colorFrom: RGBl(0,0,0,0), brightness: 0, mode: 'normal', transitionTime: 0 }))
			selectedLed = 0
			buildLedGrid()
			updateLayoutSummary()
			updateSelectionSummary()
			startPreviewLoop()
			if (usePicadeMaxMaps) {
				logEntry('log-info', `Loaded Picade Max maps (${Object.keys(buttonMap).length} labels, ${buttons.numLeds} logical LEDs, ${buttons.packetLedCount} transport LEDs, ~${buttons.maxFrameRate}fps max at 115200 baud)`)
			}
		}

		function buildLedGrid() {
			const grid = $('ledGrid')
			grid.innerHTML = ''
			const usePicadePanel =
				buttons.numLeds === PICADE_MAX_NUM_LEDS &&
				Object.keys(buttons.buttonMap || {}).length === PICADE_6_BUTTON_LABELS.length

			if (usePicadePanel) {
				const panel = document.createElement('div')
				panel.className = 'picade-panel'

				const stick = document.createElement('div')
				stick.className = 'picade-stick'
				stick.innerHTML = `
					<div class="picade-stick-ball"></div>
					<div class="picade-stick-shaft"></div>
					<div class="picade-stick-base"></div>
					<div class="picade-stick-label">JOYSTICK</div>
				`
				panel.appendChild(stick)

				const buttonPanel = document.createElement('div')
				buttonPanel.className = 'picade-buttons'

				for (const [buttonIndex, label] of PICADE_6_BUTTON_LABELS.entries()) {
					const buttonNumber = buttons.buttonMap[label]
					if (typeof buttonNumber !== 'number') continue
					const button = document.createElement('div')
					button.className = `picade-button button-${buttonIndex}`

					for (let offset = 0; offset < 4; offset++) {
						const ledIndex = (buttonNumber * 4) + offset
						const slot = document.createElement('div')
						slot.className = `picade-button-slot slot-${offset}`
						const led = document.createElement('div')
						led.className = 'led' + (ledIndex === selectedLed ? ' selected' : '')
						led.dataset.ledIndex = String(ledIndex)
						led.innerHTML = `<span class="led-idx">${ledIndex}</span>`
						led.style.background = '#000'
						led.addEventListener('click', () => selectLed(ledIndex))
						slot.appendChild(led)
						button.appendChild(slot)
					}

					const buttonLabel = document.createElement('span')
					buttonLabel.className = 'picade-button-label'
					buttonLabel.textContent = label.replace('P1:', '')
					button.appendChild(buttonLabel)
					buttonPanel.appendChild(button)
				}

				panel.appendChild(buttonPanel)
				grid.appendChild(panel)
				return
			}

			const fallback = document.createElement('div')
			fallback.className = 'picade-fallback-grid'
			for (let i = 0; i < buttons.numLeds; i++) {
				const el = document.createElement('div')
				el.className = 'led' + (i === selectedLed ? ' selected' : '')
				el.dataset.ledIndex = String(i)
				el.innerHTML = `<span class="led-idx">${i}</span>`
				el.style.background = '#000'
				el.addEventListener('click', () => selectLed(i))
				fallback.appendChild(el)
			}
			grid.appendChild(fallback)
		}

		function selectLed(i) {
			selectedLed = i
			document.querySelectorAll('.led').forEach(el => el.classList.toggle('selected', Number(el.dataset.ledIndex) === i))
			updateSelectionSummary()
			const p = previewColors[i]
			$('ledColorTo').value = rgblToHex(p.colorTo)
			$('ledColorFrom').value = rgblToHex(p.colorFrom)
			$('ledBrightness').value = p.brightness
			$('ledBrightnessVal').textContent = p.brightness
			$('ledMode').value = p.mode
			$('ledTransition').value = p.transitionTime
			$('ledTransitionVal').textContent = p.transitionTime
		}

		function getCurrentLedSettings() {
			const mode = $('ledMode').value
			const brightness = parseInt($('ledBrightness').value)
			const transitionTime = parseFloat($('ledTransition').value)
			const colorTo = hexToRGBl($('ledColorTo').value, brightness)
			const colorFrom = hexToRGBl($('ledColorFrom').value, brightness)
			return { mode, colorTo, colorFrom, brightness, transitionTime }
		}

