		// ═══════════════ MATRIX ═══════════════

		let matrixScale = 8
		let matrixDrawing = false

		function ensureMatrix() {
			const display = DISPLAY_MAP[parseInt($('matrixDisplay').value)]
			const colorOrder = COLOR_ORDERS[$('matrixColorOrder').value]
			matrix = new LedMatrix({ display, colorOrder })
			matrixScale = parseInt($('matrixScale').value) || 8
			initMatrixCanvas()
		}

		function initMatrixCanvas() {
			if (!matrix) return
			const canvas = $('matrixCanvas')
			canvas.width = matrix.width * matrixScale
			canvas.height = matrix.height * matrixScale
			renderMatrixPreview()
		}

		function renderMatrixPreview() {
			if (!matrix) return
			const canvas = $('matrixCanvas')
			const ctx = canvas.getContext('2d')
			const s = matrixScale
			ctx.fillStyle = '#000'
			ctx.fillRect(0, 0, canvas.width, canvas.height)
			for (let y = 0; y < matrix.height; y++) {
				for (let x = 0; x < matrix.width; x++) {
					const p = matrix.getPixel(x, y)
					const sc = Math.max(p.brightness / 31, 0)
					ctx.fillStyle = `rgb(${Math.round(p.red*sc)},${Math.round(p.green*sc)},${Math.round(p.blue*sc)})`
					ctx.fillRect(x * s, y * s, s, s)
				}
			}
			ctx.strokeStyle = 'rgba(255,255,255,0.06)'
			ctx.lineWidth = 1
			for (let x = 0; x <= matrix.width; x++) { ctx.beginPath(); ctx.moveTo(x*s+.5, 0); ctx.lineTo(x*s+.5, canvas.height); ctx.stroke() }
			for (let y = 0; y <= matrix.height; y++) { ctx.beginPath(); ctx.moveTo(0, y*s+.5); ctx.lineTo(canvas.width, y*s+.5); ctx.stroke() }
		}

		function matrixCanvasXY(e) {
			const canvas = $('matrixCanvas')
			const rect = canvas.getBoundingClientRect()
			const sx = canvas.width / rect.width
			const sy = canvas.height / rect.height
			return [Math.floor((e.clientX - rect.left) * sx / matrixScale), Math.floor((e.clientY - rect.top) * sy / matrixScale)]
		}

		function paintPixel(e) {
			if (!matrix) return
			const [x, y] = matrixCanvasXY(e)
			if (x < 0 || x >= matrix.width || y < 0 || y >= matrix.height) return
			const brightness = parseInt($('matrixBrightness').value)
			matrix.setPixel(x, y, hexToRGBl($('matrixColor').value, brightness))
			renderMatrixPreview()
		}

		$('matrixCanvas').addEventListener('mousedown', e => { matrixDrawing = true; paintPixel(e) })
		$('matrixCanvas').addEventListener('mousemove', e => { if (matrixDrawing) paintPixel(e) })
		window.addEventListener('mouseup', () => matrixDrawing = false)

