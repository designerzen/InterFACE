extends _base.pug

block title
	+title('Test:Picade Max Input')

block nav
	a(href="./tests.pug") All Tests

block preload 

block main
	main#test-picade-max-input
		h4 Picade Button Lighting Console
		p.subtitle Test the original 6-button Picade panel, preview per-button lighting, and send the same data to the Picade Max controller.

		.hero-card
			.hero-copy
				.hero-kicker Original Picade 6-Button Layout
				p
					| This page is for the physical arcade panel on your cabinet. Each red arcade button contains four independent corner lights.
			.workflow-inline
				.workflow-chip
					strong 1
					span Use Picade Layout
				.workflow-chip
					strong 2
					span Connect controller
				.workflow-chip
					strong 3
					span Pick a corner light
				.workflow-chip
					strong 4
					span Test fades and patterns

		.warning#serialWarning ⚠ WebSerial API is not available in this browser. Use Chrome/Edge with a secure context. Preview-only mode is active.

		.conn-bar
			.status-dot#statusDot
			.conn-main
				span.label#statusLabel Disconnected
				span.conn-hint Connect after loading the Picade layout. Electron should auto-approve the known Picade serial device.
			span.stats#statsLabel
			button#btnConnect Connect

		.tabs
			.tab.active(data-tab="buttons") Buttons
			.tab(data-tab="examples") Examples
			.tab(data-tab="tests") Tests
			.tab(data-tab="matrix") Matrix

		//- ═══════════════════════ BUTTONS PANEL ═══════════════════════
		.panel.active#panelButtons(data-tab="buttons")
			.buttons-layout
				.control-card.setup-card
					.card-heading
						span.card-step Step 1
						h5 Load the Picade layout
					p.helper-text
						| Use the original single-player Picade panel layout: six arcade buttons, four lights per button, padded to the Picade Max firmware transport size.
					.btn-row
						button#btnInitPicadeMax Use Picade Layout
					.meta-grid
						.meta-item
							span.meta-label Layout
							strong#layoutSummary Original 6-button Picade
						.meta-item
							span.meta-label Logical lights
							strong#logicalLedSummary 24
						.meta-item
							span.meta-label Transport frame
							strong#transportLedSummary 128 LEDs
						.meta-item
							span.meta-label Safe refresh
							strong#refreshSummary ~21 fps max
					details.advanced-inline
						summary Advanced transport settings
						p.advanced-copy
							| Only change these if you are deliberately testing a non-standard layout.
						.row
							label Num LEDs
							input#numLeds(type="number" value="24" min="1" max="256")
							label Refresh Hz
							input#refreshRate(type="number" value="20" min="1" max="120")
							button#btnInitButtons Apply Custom Layout

				.control-card.preview-card
					.card-heading
						span.card-step Step 2
						h5 Pick a button light
					p.helper-text
						| Click one of the four small corner lights inside a red button. The big button label shows the physical arcade button; the small light you click is the individual LED that will be edited.
					.selection-summary
						.selection-pill
							span.summary-label Button
							strong#selectedButtonLabel Y
						.selection-pill
							span.summary-label Light
							strong#selectedLightLabel Top left
						.selection-pill
							span.summary-label LED index
							strong#selectedIdx 0
					.led-grid#ledGrid

				.control-card.effects-card
					.card-heading
						span.card-step Step 3
						h5 Choose the lighting behaviour
					p.helper-text
						| Use steady color for static tests, or use fade modes to mimic the button-press flash behaviour you want in the final app.
					.row
						label Effect
						select#ledMode
							option(value="normal") Steady color
							option(value="blink") Blink
							option(value="fade") One-way fade
							option(value="fade sweep") Pulse / sweep
					.row
						label Main color
						input#ledColorTo(type="color" value="#ff4400")
					.row
						label Fade to
						input#ledColorFrom(type="color" value="#000000")
					.row
						label Brightness
						input#ledBrightness(type="range" min="0" max="31" value="16")
						span.val#ledBrightnessVal 16
					.row
						label Fade time (s)
						input#ledTransition(type="range" min="0" max="5" step="0.1" value="1")
						span.val#ledTransitionVal 1
					.btn-row
						button#btnApplyLed Apply to This Light
						button#btnApplyButton Apply to Whole Button
						button#btnFlashButton Preview Fade
					.btn-row
						button#btnSetAll Apply to All Lights
						button#btnClearButton Clear Button
						button#btnClearAll.danger Blackout All

		.panel#panelExamples(data-tab="examples")
			.examples-layout
				.control-card.examples-card
					.card-heading
						span.card-step Picade Examples
						h5 Upstream demo ports
					p.helper-text
						| These are direct browser-side ports of the tested Picade button demos from the upstream reference implementation.
					.btn-row
						button#btnRunExamplePyButtons Run Button Demo
						button#btnRunExamplePy3 Run Extended Demo
						button#btnStopExamples.danger Stop Demo

		.panel#panelTests(data-tab="tests")
			.examples-layout
				.control-card.examples-card
					.card-heading
						span.card-step Button Patterns
						h5 Guided light tests
					p.helper-text
						| Use these to test motion, direction, fade timing, and whole-panel coverage without manually editing every light.
					.row
						label Quick pattern
						select#buttonPatternSelect
							option(value="rainbow_fade") rainbow_fade
							option(value="sparkle_fade") sparkle_fade
							option(value="panel_wave") panel_wave
							option(value="center_out") center_out
							option(value="edge_in") edge_in
							option(value="column_scan") column_scan
							option(value="row_scan") row_scan
							option(value="alternating_pairs") alternating_pairs
							option(value="label_cycle") label_cycle
					.btn-row
						button#btnRunButtonPattern Run Pattern
						button#btnStopExamples.danger Stop Demo

				.control-card.examples-card
					.card-heading
						span.card-step Attract Mode
						h5 Whole-panel motion tests
					p.helper-text
						| These patterns continuously animate the six-button panel and are useful for checking sequencing, direction, and timing.
					.row
						label Motion
						select#attractPattern
							option(value="linear") linear
							option(value="radial") radial
							option(value="circular") circular
					.row
						label Direction
						select#attractDirection
							option(value="left_to_right") left_to_right
							option(value="right_to_left") right_to_left
							option(value="top_to_bottom") top_to_bottom
							option(value="bottom_to_top") bottom_to_top
					.row
						label Lit color
						input#attractColorOn(type="color" value="#1f1f00")
					.row
						label Dark color
						input#attractColorOff(type="color" value="#000000")
					.row
						label Step delay (ms)
						input#attractDelay(type="range" min="10" max="500" step="10" value="50")
						span.val#attractDelayVal 50
					.btn-row
						button#btnAttractStart Start Attract Mode
						button#btnAttractStop.danger Stop Attract Mode

				.control-card.examples-card
					.card-heading
						span.card-step Transport Tests
						h5 Raw protocol tools
					p.helper-text
						| Use this only when you need to inspect or prove the exact bytes going to the controller.
					.diag-bar
						button#btnTestPattern Send Test Pattern
						button#btnSendRaw Send Raw Text…
						label.diag-toggle
							input#chkHexDump(type="checkbox")
							| Show TX hex dump
					.port-info#portInfo
					.log-header
						span Serial Log
						button#btnClearLog Clear
					.serial-log#serialLog

		//- ═══════════════════════ MATRIX PANEL ═══════════════════════
		.panel#panelMatrix(data-tab="matrix")
			.row
				label Display
				select#matrixDisplay
					option(value="0") Galactic Unicorn (53×11)
					option(value="1") Interstate75 (128×32)
			.row
				label Color Order
				select#matrixColorOrder
					option(value="RGB") RGB
					option(value="RBG") RBG
					option(value="GBR") GBR
					option(value="GRB") GRB
					option(value="BGR") BGR
					option(value="BRG") BRG
			.row
				label Draw Color
				input#matrixColor(type="color" value="#ff0044")
			.row
				label Brightness
				input#matrixBrightness(type="range" min="0" max="31" value="16")
				span.val#matrixBrightnessVal 16
			.row
				label Pixel scale
				input#matrixScale(type="number" value="8" min="1" max="20" style="width:50px")
				button#btnInitMatrix Init / Resize

			.section-title Canvas (click / drag to draw)
			.matrix-wrap#matrixWrap
				canvas#matrixCanvas

			.btn-row
				button#btnFillMatrix Fill
				button#btnClearMatrix.danger Clear
				button#btnSendMatrix Send to Display

			.section-title Matrix Example
			.btn-row
				button#btnRunExamplePyMatrix Run examples.py Matrix
				button#btnStopMatrixExample.danger Stop Demo

block styles
	style.
		#test-picade-max-input {
			--bg: #111317;
			--surface: #191d23;
			--surface2: #222932;
			--surface3: #2a313c;
			--border: #38414d;
			--text: #e8edf2;
			--textDim: #9ba6b2;
			--accent: #f7b538;
			--accentDim: #ab7720;
			--danger: #e15a4f;
			--ok: #46c274;
			--mono: 'Consolas', 'Courier New', monospace;
			font-family: var(--mono);
			font-size: 13px;
			padding: 16px;
			width: 100%;
			max-width: none;
			box-sizing: border-box;
			color: var(--text);
			background:
				radial-gradient(circle at top left, rgba(247,181,56,.08), transparent 28%),
				radial-gradient(circle at top right, rgba(70,194,116,.06), transparent 24%),
				linear-gradient(180deg, #12151a 0, #0d1014 100%);
		}

		#test-picade-max-input h4 {
			font-size: 24px;
			margin-bottom: 6px;
			color: #f7f2e8;
			letter-spacing: .4px;
		}

		#test-picade-max-input .subtitle {
			font-size: 13px;
			color: var(--textDim);
			margin-bottom: 18px;
			max-width: 920px;
			line-height: 1.5;
		}

		#test-picade-max-input .hero-card {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
			gap: 12px;
			padding: 16px 18px;
			margin-bottom: 14px;
			border: 1px solid var(--border);
			border-radius: 14px;
			background:
				linear-gradient(135deg, rgba(247,181,56,.13), rgba(247,181,56,0) 35%),
				linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0)),
				var(--surface);
			box-shadow: 0 16px 36px rgba(0,0,0,.22);
		}

		#test-picade-max-input .hero-kicker {
			display: inline-block;
			margin-bottom: 10px;
			font-size: 11px;
			letter-spacing: 1.6px;
			text-transform: uppercase;
			color: var(--accent);
		}

		#test-picade-max-input .hero-copy p {
			margin: 0;
			font-size: 13px;
			line-height: 1.6;
			color: #d9dee5;
		}

		#test-picade-max-input .workflow-inline {
			display: flex;
			flex-wrap: wrap;
			gap: 10px;
			align-items: center;
			justify-content: flex-end;
		}

		#test-picade-max-input .workflow-chip {
			display: inline-grid;
			grid-template-columns: 24px auto;
			gap: 10px;
			align-items: center;
			padding: 9px 12px;
			border: 1px solid rgba(255,255,255,.06);
			border-radius: 999px;
			background: rgba(255,255,255,.03);
		}

		#test-picade-max-input .workflow-chip strong {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 24px;
			height: 24px;
			border-radius: 50%;
			background: var(--accent);
			color: #17120a;
			font-size: 11px;
		}

		#test-picade-max-input .workflow-chip span {
			color: #d6dbe2;
			line-height: 1.2;
			white-space: nowrap;
			font-size: 11px;
		}

		#test-picade-max-input .warning {
			background: #443300;
			border: 1px solid #886600;
			color: #ffcc44;
			padding: 8px 12px;
			border-radius: 4px;
			margin-bottom: 12px;
			font-size: 12px;
			display: none;
		}

		#test-picade-max-input .conn-bar {
			display: flex;
			align-items: center;
			gap: 14px;
			padding: 14px 16px;
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: 12px;
			margin-bottom: 14px;
			box-shadow: 0 10px 24px rgba(0,0,0,.18);
		}

		#test-picade-max-input .status-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
			background: var(--danger);
			flex-shrink: 0;

			&.ok { background: var(--ok); }
		}

		#test-picade-max-input .conn-main {
			display: flex;
			flex-direction: column;
			gap: 3px;
			flex: 1;
		}

		#test-picade-max-input .conn-bar .label {
			font-size: 13px;
			color: #eef3f8;
		}

		#test-picade-max-input .conn-hint {
			font-size: 11px;
			color: var(--textDim);
		}

		#test-picade-max-input button {
			font-family: var(--mono);
			font-size: 12px;
			padding: 8px 14px;
			border: 1px solid var(--border);
			border-radius: 8px;
			background: var(--surface2);
			color: var(--text);
			cursor: pointer;
			transition: .15s;

			&:hover { background: var(--accent); color: #17120a; border-color: var(--accent); }
			&.danger:hover { background: var(--danger); border-color: var(--danger); }
			&:disabled { opacity: .4; cursor: default; background: var(--surface2); color: var(--textDim); border-color: var(--border); }
		}

		#test-picade-max-input .tabs {
			display: flex;
			flex-wrap: wrap;
			gap: 2px;
			margin-bottom: 0;
		}

		#test-picade-max-input .tab {
			padding: 7px 20px;
			background: var(--surface2);
			border: 1px solid var(--border);
			border-bottom: none;
			border-radius: 6px 6px 0 0;
			cursor: pointer;
			color: var(--textDim);
			font-size: 12px;

			&.active { background: var(--surface); color: var(--accent); border-color: var(--border); }
		}

		#test-picade-max-input .panel {
			display: none;
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: 0 10px 10px 10px;
			padding: 18px;

			&.active { display: block; }
		}

		#test-picade-max-input .buttons-layout {
			display: grid;
			grid-template-columns: repeat(12, minmax(0, 1fr));
			gap: 16px;
			align-items: start;
		}

		#test-picade-max-input .examples-layout {
			display: grid;
			grid-template-columns: repeat(12, minmax(0, 1fr));
			gap: 16px;
			align-items: start;
		}

		#test-picade-max-input .control-card {
			padding: 16px;
			border: 1px solid rgba(255,255,255,.05);
			border-radius: 14px;
			background:
				linear-gradient(180deg, rgba(255,255,255,.025), rgba(255,255,255,0)),
				var(--surface2);
			box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
			height: 100%;
			box-sizing: border-box;
		}

		#test-picade-max-input .preview-card {
			grid-column: 1 / -1;
			grid-row: auto;
		}

		#test-picade-max-input .setup-card {
			grid-column: span 4;
		}

		#test-picade-max-input .effects-card {
			grid-column: span 8;
		}

		#test-picade-max-input .examples-card {
			grid-column: span 4;
		}

		#test-picade-max-input .card-heading {
			margin-bottom: 10px;
		}

		#test-picade-max-input .card-heading h5 {
			margin: 3px 0 0;
			font-size: 17px;
			color: #f4f7fa;
		}

		#test-picade-max-input .card-step {
			font-size: 11px;
			text-transform: uppercase;
			letter-spacing: 1.4px;
			color: var(--accent);
		}

		#test-picade-max-input .helper-text,
		#test-picade-max-input .advanced-copy {
			margin: 0 0 12px;
			font-size: 12px;
			line-height: 1.55;
			color: var(--textDim);
		}

		#test-picade-max-input .meta-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
			gap: 8px;
			margin-bottom: 12px;
		}

		#test-picade-max-input .meta-item,
		#test-picade-max-input .selection-pill {
			padding: 10px 12px;
			border-radius: 10px;
			background: rgba(0,0,0,.16);
			border: 1px solid rgba(255,255,255,.05);
		}

		#test-picade-max-input .meta-label,
		#test-picade-max-input .summary-label {
			display: block;
			margin-bottom: 4px;
			font-size: 10px;
			text-transform: uppercase;
			letter-spacing: 1.2px;
			color: var(--textDim);
		}

		#test-picade-max-input .meta-item strong,
		#test-picade-max-input .selection-pill strong {
			font-size: 13px;
			color: #f2f6fa;
		}

		#test-picade-max-input .selection-summary {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
			gap: 8px;
			margin-bottom: 12px;
		}

		#test-picade-max-input details {
			border: 1px solid rgba(255,255,255,.06);
			border-radius: 10px;
			background: rgba(0,0,0,.12);
		}

		#test-picade-max-input summary {
			cursor: pointer;
			padding: 12px 14px;
			color: #e5ebf2;
		}

		#test-picade-max-input .advanced-shell {
			margin-bottom: 14px;
			background: var(--surface);
		}

		#test-picade-max-input .advanced-shell[open],
		#test-picade-max-input .advanced-inline[open] {
			padding-bottom: 12px;
		}

		#test-picade-max-input .advanced-shell > :not(summary),
		#test-picade-max-input .advanced-inline > :not(summary) {
			padding-left: 14px;
			padding-right: 14px;
		}

		#test-picade-max-input .row {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 8px;
			margin-bottom: 8px;

			& label { font-size: 11px; color: var(--textDim); min-width: 110px; }
			& input[type=number] { width: 80px; font-family: var(--mono); font-size: 12px; padding: 6px 8px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); }
			& select { font-family: var(--mono); font-size: 12px; padding: 6px 8px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); }
			& input[type=color] { width: 44px; height: 30px; border: 1px solid var(--border); border-radius: 8px; padding: 0; cursor: pointer; background: none; }
			& input[type=range] { flex: 1 1 180px; min-width: 140px; accent-color: var(--accent); }
			& .val { font-size: 11px; color: var(--accent); width: 30px; text-align: right; }
		}

		#test-picade-max-input .section-title {
			font-size: 11px;
			color: var(--accent);
			margin: 16px 0 8px;
			border-bottom: 1px solid rgba(255,255,255,.06);
			padding-bottom: 5px;
			text-transform: uppercase;
			letter-spacing: 1.3px;
		}

		#test-picade-max-input .btn-row {
			display: flex;
			gap: 6px;
			flex-wrap: wrap;
			margin-top: 8px;
		}

		#test-picade-max-input .stats {
			font-size: 11px;
			color: var(--textDim);
			margin-left: auto;
		}

		#test-picade-max-input .diag-bar {
			display: flex;
			gap: 6px;
			align-items: center;
			flex-wrap: wrap;
			margin-bottom: 8px;
		}

		#test-picade-max-input .diag-toggle {
			font-size: 11px;
			color: var(--textDim);
			cursor: pointer;
			display: flex;
			align-items: center;
			gap: 4px;
			margin-left: auto;
		}

		#test-picade-max-input .port-info {
			font-size: 11px;
			color: var(--textDim);
			margin-bottom: 10px;

			&:empty { display: none; }
		}

		#test-picade-max-input .log-header {
			display: flex;
			align-items: center;
			justify-content: space-between;
			margin-bottom: 8px;
			font-size: 11px;
			color: #e2e8ef;
		}

		#test-picade-max-input .log-hex {
			color: #7b68ee;
			font-size: 10px;
			letter-spacing: 0.5px;
		}

		#test-picade-max-input .serial-log {
			background: #0a0a0f;
			border: 1px solid var(--border);
			border-radius: 4px;
			padding: 8px;
			margin-bottom: 14px;
			max-height: 160px;
			overflow-y: auto;
			font-size: 11px;
			line-height: 1.5;
			white-space: pre-wrap;
			word-break: break-all;

			& .log-in { color: #6be06b; }
			& .log-out { color: #6ba8e0; }
			& .log-err { color: #e06b6b; }
			& .log-info { color: #888; }
			& .log-time { color: #555; margin-right: 6px; }
		}

		#test-picade-max-input .led-grid {
			display: flex;
			justify-content: center;
			padding: 14px;
			background:
				linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0)),
				#11151a;
			border: 1px solid rgba(255,255,255,.06);
			border-radius: 14px;
			margin: 8px 0 0;
			min-height: 320px;
			overflow: auto;
		}

		#test-picade-max-input .picade-panel {
			display: grid;
			grid-template-columns: 220px minmax(320px, 520px);
			align-items: center;
			justify-content: center;
			column-gap: 56px;
			width: 100%;
