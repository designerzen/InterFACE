			#test-picade-max-input .meta-grid {
				grid-template-columns: 1fr;
			}

			#test-picade-max-input .picade-stick {
				width: 150px;
				height: 150px;
			}

			#test-picade-max-input .picade-buttons {
				grid-template-columns: repeat(2, minmax(92px, 1fr));
				padding: 0;
			}

			#test-picade-max-input .picade-button.button-3,
			#test-picade-max-input .picade-button.button-4,
