doctype html
html(lang="en-GB")
	head
		meta(charset="utf-8")
		meta(name="viewport" content="width=device-width,initial-scale=1")
		title PhotoSYNTH LiteRT Blendshape Probe
		style.
			:root {
				color-scheme: dark;
				font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				background: #161819;
				color: #f4f4f0;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-block-size: 100svh;
				background: #161819;
			}

			main {
				display: grid;
				grid-template-columns: minmax(20rem, 30rem) minmax(20rem, 1fr);
				gap: 1rem;
				align-items: start;
				padding: 1rem;
			}

			h1,
			p {
				margin-block-start: 0;
			}

			button {
				border: 1px solid #778086;
				border-radius: 6px;
				padding: 0.65rem 0.9rem;
				background: #e9f0f1;
				color: #111517;
				font: inherit;
				font-weight: 650;
				cursor: pointer;
			}

			button:disabled {
				opacity: 0.45;
				cursor: not-allowed;
			}

			.controls,
			.preview {
				border: 1px solid #384248;
				border-radius: 8px;
				background: #202426;
				box-shadow: 0 1rem 4rem #0008;
			}

			.controls {
				display: grid;
				gap: 0.8rem;
				padding: 1rem;
			}

			.button-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}

			output,
			pre {
				display: block;
				border-radius: 6px;
				background: #111517;
				color: #e8f7e1;
			}

			output {
				min-block-size: 2.25rem;
				padding: 0.65rem 0.75rem;
			}

			pre {
				overflow: auto;
				max-block-size: 40svh;
				margin: 0;
				padding: 0.85rem;
				white-space: pre-wrap;
				font-size: 0.82rem;
			}

			.preview {
				position: relative;
				overflow: hidden;
				aspect-ratio: 4 / 3;
				min-block-size: 18rem;
			}

			video,
			canvas {
				position: absolute;
				inset: 0;
				inline-size: 100%;
				block-size: 100%;
				object-fit: cover;
			}

			canvas {
				pointer-events: none;
			}

			@media (max-width: 820px) {
				main {
					grid-template-columns: 1fr;
				}
			}
	body
		main
			section.controls
				h1 LiteRT Blendshape Probe
				p Compare MediaPipe's exposed face blendshapes with the raw bundled face_blendshapes.tflite model.
				.button-row
					button#button-start(type="button") Start camera
					button#button-probe(type="button" disabled) Probe current frame
				output#status(role="status" aria-live="polite") Page loaded. JavaScript module has not reported in yet.
				output#summary Waiting for module.
				pre#details No probe data yet.

			section.preview
				video#webcam(autoplay playsinline muted width="640" height="480")
				canvas#overlay(width="640" height="480")

		script.
			window.addEventListener('error', event => {
				const status = document.getElementById('status')
				const details = document.getElementById('details')
				if (status) status.value = `Error: ${event.message}`
				if (details) details.textContent = `${event.message}\n${event.filename}:${event.lineno}:${event.colno}`
			})
			window.addEventListener('unhandledrejection', event => {
				const status = document.getElementById('status')
				const details = document.getElementById('details')
				const reason = event.reason?.stack || event.reason?.message || String(event.reason)
				if (status) status.value = `Unhandled promise rejection`
				if (details) details.textContent = reason
			})
		script(type="module" src="./tests/test.litert.js")
